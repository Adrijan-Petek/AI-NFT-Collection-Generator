# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_nft_collection_generator"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_XXXX
CLERK_SECRET_KEY=sk_test_XXXX

# Stripe
STRIPE_SECRET_KEY=sk_test_XXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXX
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXX
STRIPE_PRICE_PRO_MONTHLY=price_XXXX

# Pinata / IPFS
PINATA_JWT=pinata_jwt_token
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# Blockchain
NEXT_PUBLIC_DEFAULT_CHAIN=base
PRIVATE_KEY=0xabc
BASE_RPC_URL=https://mainnet.base.org
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your-key
POLYGON_RPC_URL=https://polygon-rpc.com

# AI provider
AI_PROVIDER=openai
AI_API_KEY=replace_me

# OpenSea ERC-8257 Tool Registry (Base)
OPENSEA_TOOL_NAME="AI NFT Collection Generator Pro Tool"
OPENSEA_TOOL_DESCRIPTION="Onchain-gated NFT generation tool"
OPENSEA_TOOL_ENDPOINT="https://your-domain.com/api/generate"
OPENSEA_TOOL_OWNER="0x868EDB819AF54a9C938DEA4c2e027FE050b18d0A"
PRO_NFT_GATE="0x0000000000000000000000000000000000000000"
PRO_MIN_NFT_BALANCE=1
PRO_TOKEN_GATE="0x0000000000000000000000000000000000000000"
PRO_MIN_TOKEN_BALANCE=0
PRO_PAY_PER_CALL_WEI=0
